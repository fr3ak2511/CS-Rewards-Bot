# 1. OS Generated Files (Junk files your computer makes automatically)
.DS_Store
Thumbs.db

# 2. Python Caches & Virtual Environments
__pycache__/
*.pyc
*.pyo
venv/
env/

# 3. Secrets (NEVER upload API keys or passwords to GitHub)
.env

# 4. Bot Output & State Files 
# We ignore these locally so GitHub Actions can manage them without causing conflicts
claim_history.json
bot_meta.json

# 5. Screenshots and HTML logs generated by the bot
*.png
*.html
